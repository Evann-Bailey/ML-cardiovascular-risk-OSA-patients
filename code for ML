import os
os.environ["SCIPY_ARRAY_API"] = "1"

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
from collections import defaultdict
from sklearn.model_selection import train_test_split, GridSearchCV, StratifiedKFold
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import accuracy_score, f1_score, precision_score, recall_score, confusion_matrix, roc_auc_score
from sklearn.impute import SimpleImputer
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.tree import DecisionTreeClassifier
from sklearn.naive_bayes import GaussianNB
from sklearn.neighbors import KNeighborsClassifier
from sklearn.svm import SVC
from sklearn.feature_selection import SelectKBest, f_classif
from imblearn.over_sampling import SMOTE
from xgboost import XGBClassifier
from catboost import CatBoostClassifier
from sklearn.metrics import roc_curve

warnings.filterwarnings("ignore")

# --- Data Loading ---
data_path = r"C:\Users\16156\OneDrive\Desktop\Capstone Final for April\New folder\Final_all_features_combined.csv"
df = pd.read_csv(data_path)

df.rename(columns=lambda x: x.lower(), inplace=True)

# Control: 1, Case: 0
df['group'] = df['group'].map({'control': 1, 'case': 0})

drop_cols = ['subject_id', 'race', 'split', 'group'] 

if 'race_white' in df.columns:
    df['race_white'] = df['race_white'].astype(int)

X = df.drop(columns=drop_cols, errors='ignore').select_dtypes(include=['int64', 'float64'])
y = df['group']

X_train_raw, X_test_raw, y_train, y_test = train_test_split(
    X, y, test_size=0.20, random_state=42, stratify=y
)

print(f" Total subjects: {len(df)}")
print(f" Training set size: {len(y_train)}")
print(f" Test set size: {len(y_test)}")

# --- Preprocessing ---
imputer = SimpleImputer(strategy='mean')
scaler = StandardScaler()

X_train_imputed = imputer.fit_transform(X_train_raw)
X_test_imputed = imputer.transform(X_test_raw)

X_train_scaled_full = scaler.fit_transform(X_train_imputed)
X_test_scaled_full = scaler.transform(X_test_imputed)

X_train_res_full, y_train_res = SMOTE(random_state=42).fit_resample(X_train_scaled_full, y_train)

# --- Feature Selection (Top 20) ---
selector = SelectKBest(score_func=f_classif, k=20) 
X_train_res = selector.fit_transform(X_train_res_full, y_train_res)
X_test_scaled = selector.transform(X_test_scaled_full)

selected_features = X.columns[selector.get_support()].tolist()
print(f" Features reduced from {X.shape[1]} to {X_train_res.shape[1]}")

# --- CHART 1 - Top 20 General Predictors (Statistical) ---
all_feature_scores = selector.scores_
importance_df = pd.DataFrame({
    'Feature': X.columns,
    'F_Score': all_feature_scores
}).sort_values(by='F_Score', ascending=False)

plt.figure(figsize=(12, 8))
sns.barplot(x='F_Score', y='Feature', data=importance_df.head(20), palette='viridis')
plt.title('Top 20 General Predictors (ANOVA F-Score Ranking)', fontsize=14)
plt.xlabel('F-Score (Statistical Significance)')
plt.ylabel('Feature')
plt.tight_layout()
plt.savefig("Top_20_General_Predictors.png")
plt.show()

# --- Model Definitions ---
models_with_grids = {
    "XGB": (
        XGBClassifier(use_label_encoder=False, eval_metric="logloss", random_state=42, n_jobs=-1),
        {"n_estimators": [100], "learning_rate": [0.05, 0.1], "max_depth": [2, 3, 4]}
    ), 
    "RF": (
        RandomForestClassifier(random_state=42, n_jobs=-1),
        {"n_estimators": [100, 200], "max_depth": [2, 3, 4]}
    ), 
    "SVM_RBF": (
        SVC(kernel="rbf", probability=True),
        {"C": [0.1, 1, 10], "gamma": ["scale", "auto"]}
    ), 
    "LR": (
        LogisticRegression(max_iter=1000, n_jobs=-1),
        {"C": [0.1, 1, 10], "solver": ["lbfgs", "liblinear"]}
    ),
    "DT": (
        DecisionTreeClassifier(random_state=42),
        {"max_depth": [3], "criterion": ["gini", "entropy"]}
    ), 
    "NB": (
        GaussianNB(),
        {"var_smoothing": [1e-9, 1e-8]}
    ),
    "KNN": (
        KNeighborsClassifier(n_jobs=-1),
        {"n_neighbors": [3, 5, 7]}
    ),
    "CatBoost": (
        CatBoostClassifier(verbose=0, random_state=42, thread_count=-1, task_type="CPU"),
        {"iterations": [100, 200], "depth": [4, 6]}
    )
}

# --- Training and Evaluation ---
results = []
best_estimators = {}

for name, (model, param_grid) in models_with_grids.items():
    print(f" Tuning {name}...")
    grid = GridSearchCV(model, param_grid, cv=StratifiedKFold(n_splits=3), scoring="f1", n_jobs=-1)
    grid.fit(X_train_res, y_train_res)
    
    best_model = grid.best_estimator_
    best_estimators[name] = best_model
    
    y_test_pred = best_model.predict(X_test_scaled)
    y_test_proba = best_model.predict_proba(X_test_scaled)[:, 1]

    results.append({
        "Model": name,
        "Train F1": f1_score(y_train_res, best_model.predict(X_train_res)) * 100,
        "Test Accuracy": accuracy_score(y_test, y_test_pred) * 100,
        "Test Precision": precision_score(y_test, y_test_pred) * 100,
        "Test Recall": recall_score(y_test, y_test_pred) * 100,
        "Test F1": f1_score(y_test, y_test_pred) * 100,
        "ROC AUC": roc_auc_score(y_test, y_test_proba) * 100
    })

# Final Results Table
results_df = pd.DataFrame(results).sort_values("Test F1", ascending=False)
print("\n Final Performance Table:")
print(results_df.round(2))

# --- CHART 2 - Top 20 Model-Specific Predictors (CatBoost) ---
if "CatBoost" in best_estimators:
    cb_model = best_estimators["CatBoost"]
    importances = cb_model.get_feature_importance()
    
    feature_importance_df = pd.DataFrame({
        'Feature': selected_features,
        'Importance': importances
    }).sort_values(by='Importance', ascending=False)

    plt.figure(figsize=(12, 8))
    sns.barplot(x='Importance', y='Feature', data=feature_importance_df.head(20), palette='magma')
    plt.title('Top 20 Most Important Predictors (CatBoost Model)', fontsize=14)
    plt.tight_layout()
    plt.savefig("Top_20_CatBoost_Features.png")
    plt.show()

# --- ROC Curve Comparison ---
plt.figure(figsize=(10, 7))
top_models = results_df['Model'].head(4).tolist()

for name in top_models:
    model = best_estimators[name]
    y_test_proba = model.predict_proba(X_test_scaled)[:, 1]
    fpr, tpr, _ = roc_curve(y_test, y_test_proba)
    plt.plot(fpr, tpr, label=f'{name} (AUC = {roc_auc_score(y_test, y_test_proba)/100:.2f})')

plt.plot([0, 1], [0, 1], 'k--', label='Random Guess')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate')
plt.title('Multi-Model ROC Curve Comparison')
plt.legend(loc='lower right')
plt.grid(alpha=0.3)
plt.savefig("Multi_Model_ROC_Comparison.png")
plt.show()

# --- File Exports ---
results_df.to_csv("Strokemodel_results_optimized.csv", index=False)
importance_df.to_csv("General_Top_Features_ANOVA.csv", index=False)
if "CatBoost" in best_estimators:
    feature_importance_df.to_csv("CatBoost_Top_Features.csv", index=False)

print(" All charts saved. Results and Feature Importances exported to CSV.")
